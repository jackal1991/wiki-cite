# Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# Wikipedia credentials (for authenticated edits)
WIKIPEDIA_USERNAME=your_bot_username
WIKIPEDIA_PASSWORD=your_bot_password

# Optional: API keys for source finding
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_EMAIL=your_email@example.com
# Brave Search API key, used for general web/news source search
# (get one at https://brave.com/search/api/)
BRAVE_API_KEY=

# Flask configuration
FLASK_SECRET_KEY=your_secret_key_here
FLASK_ENV=development
